# Brand Archive 환경변수 예시.
# 이 파일을 .env 로 복사한 뒤 값만 채우세요.

# === DB ===
# 로컬 개발: 파일 SQLite (libsql 어댑터가 file: 도 지원)
DATABASE_URL="file:./dev.db"

# 프로덕션 (Vercel/Netlify) 배포 시:
#   1) DATABASE_URL 을 Turso 의 libsql URL 로 교체
#      예: DATABASE_URL="libsql://my-archive-myorg.turso.io"
#   2) TURSO_AUTH_TOKEN 채우기
TURSO_AUTH_TOKEN=

# === YouTube Data API v3 ===
# 발급: https://console.cloud.google.com/ → API 사용설정 → API 키 발급
# 키가 없으면 실시간 검색은 비활성화 (URL 붙여넣기 저장은 동작)
YOUTUBE_API_KEY=
